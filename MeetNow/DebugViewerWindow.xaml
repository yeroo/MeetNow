<Window x:Class="MeetNow.DebugViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MeetNow — Debug WebView"
        Width="400" Height="120"
        WindowStartupLocation="CenterScreen"
        Background="#1B1A19">
    <StackPanel Margin="12">
        <TextBlock Text="Select WebView instance to inspect:"
                   Foreground="#CCCCCC" FontSize="12" Margin="0,0,0,8"/>
        <ComboBox x:Name="InstanceCombo"
                  SelectionChanged="InstanceCombo_SelectionChanged"
                  Background="#2A2A2A" Foreground="#EEEEEE" FontSize="13"/>
    </StackPanel>
</Window>
